<Window
    x:Class="Library.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    Background="AliceBlue"
    WindowState="Maximized"
    mc:Ignorable="d">
    <StackPanel>
        <ListView Margin="20" ItemsSource="{Binding Books}">
            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Width="150"
                        DisplayMemberBinding="{Binding BookId}"
                        Header="Book Id" />
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding Title}"
                        Header="Title" />
                    <GridViewColumn
                        Width="120"
                        DisplayMemberBinding="{Binding Author}"
                        Header="Author" />
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding Genre}"
                        Header="Genre" />
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding Price}"
                        Header="Price" />
                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding IsAvailable}"
                        Header="Is available" />
                </GridView>
            </ListView.View>
        </ListView>
        <StackPanel
            Grid.Row="2"
            Margin="20"
            Orientation="Vertical">
            <StackPanel Margin="0,8">
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Text="Book Title" />
                <TextBox Padding="6" Text="{Binding NewTitle}" />
            </StackPanel>
            <StackPanel Margin="0,8">
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Text="Book Author" />
                <TextBox Padding="6" Text="{Binding NewAuthor}" />
            </StackPanel>
            <StackPanel Margin="0,8">
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Text="Book Genre" />
                <TextBox Padding="6" Text="{Binding NewGenre}" />
            </StackPanel>
            <StackPanel Margin="0,8">
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Text="Book Price" />
                <TextBox Padding="6" Text="{Binding NewPrice}" />
            </StackPanel>
            <CheckBox Content="Is available" IsChecked="{Binding NewIsAvailable}" />
            <Button
                Width="120"
                Height="36"
                Margin="0,8,0,0"
                HorizontalAlignment="Left"
                Background="#007ACC"
                BorderBrush="{x:Null}"
                Command="{Binding AddBookCommand}"
                Content="Add"
                Cursor="Hand"
                FontWeight="Bold"
                Foreground="White">
                <Button.Effect>
                    <DropShadowEffect
                        BlurRadius="4"
                        Opacity="0.3"
                        ShadowDepth="2" />
                </Button.Effect>
            </Button>
        </StackPanel>
        <Button Content="Delete"
        Width="100"
        Margin="10"
        Command="{Binding DeleteBookCommand}"
        CommandParameter="{Binding SelectedItem, ElementName=BooksListView}" />
        <ListView x:Name="BooksListView"
          ItemsSource="{Binding Books}">
    </StackPanel>
</Window>
