<Window
    x:Class="Library.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Library"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Library"
    Width="800"
    Height="450"
    Background="AliceBlue"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Books List  -->
        <ListView
            x:Name="BooksListView"
            Grid.Row="0"
            ItemsSource="{Binding Books}"
            SelectedItem="{Binding SelectedBook}">

            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Width="100"
                        DisplayMemberBinding="{Binding BookId}"
                        Header="Book Id" />

                    <GridViewColumn
                        Width="220"
                        DisplayMemberBinding="{Binding Title}"
                        Header="Title" />

                    <GridViewColumn
                        Width="180"
                        DisplayMemberBinding="{Binding Author}"
                        Header="Author" />

                    <GridViewColumn
                        Width="120"
                        DisplayMemberBinding="{Binding Genre}"
                        Header="Genre" />

                    <GridViewColumn
                        Width="80"
                        DisplayMemberBinding="{Binding Price}"
                        Header="Price" />

                    <GridViewColumn
                        Width="90"
                        DisplayMemberBinding="{Binding IsAvailable}"
                        Header="Available" />
                </GridView>
            </ListView.View>

        </ListView>

        <!--  Add / Edit Book  -->
        <StackPanel Grid.Row="1" Margin="0,20,0,0">

            <TextBlock FontWeight="SemiBold" Text="Book Title" />
            <TextBox Margin="0,5,0,10" Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock FontWeight="SemiBold" Text="Book Author" />
            <TextBox Margin="0,5,0,10" Text="{Binding NewAuthor, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock FontWeight="SemiBold" Text="Book Genre" />
            <TextBox Margin="0,5,0,10" Text="{Binding NewGenre, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock FontWeight="SemiBold" Text="Book Price" />
            <TextBox Margin="0,5,0,10" Text="{Binding NewPrice, UpdateSourceTrigger=PropertyChanged}" />

            <CheckBox
                Margin="0,5,0,15"
                Content="Is Available"
                IsChecked="{Binding NewIsAvailable}" />

            <StackPanel Orientation="Horizontal">

                <Button
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#007ACC"
                    BorderThickness="0"
                    Command="{Binding AddBookCommand}"
                    Content="Add"
                    FontWeight="Bold"
                    Foreground="White" />

                <Button
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#28A745"
                    BorderThickness="0"
                    Command="{Binding EditBookCommand}"
                    Content="Update"
                    FontWeight="Bold"
                    Foreground="White" />

                <Button
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="IndianRed"
                    BorderThickness="0"
                    Command="{Binding DeleteBookCommand}"
                    Content="Delete"
                    FontWeight="Bold"
                    Foreground="White" />

            </StackPanel>

        </StackPanel>

    </Grid>

</Window>